    List<int[]> boards = new ArrayList<>();

    public void makeAll3x3Boards() {
        for (int x = 1; x <= 3; x++) {
            for (int y = 0; y <= x; y++) {
                for (int z = 0; z <= y; z++) {
                    boards.add(new int[]{x, y, z});
                }
            }
        }
    }

    public void makeAllBoards() {
        for (int a = 1; a <= 10; a++) {
            for (int b = 0; b <= a; b++) {
                for (int c = 0; c <= b; c++) {
                    for (int d = 0; d <= c; d++) {
                        for (int e = 0; e <= d; e++) {
                            for (int f = 0; f <= e; f++) {
                                for (int g = 0; g <= f; g++) {
                                    for (int h = 0; h <= g; h++) {
